# 运行环境: dev / production
# production 环境下使用默认密钥会拒绝启动 (SEC-1 fail-closed)
ENV=dev

# 数据库
DATABASE_URL=sqlite:///./user_salse.db

# JWT
SECRET_KEY=dev-secret-key-32bytes-minimum-xxxxx
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# 邀请码签名密钥
INVITE_CODE_SECRET=dev-invite-secret-change-me-xxxxx

# License 签名密钥
LICENSE_SECRET=dev-license-secret-change-me-xxxxx

# License 验证 API Key (舆情系统调用)
LICENSE_API_KEY=dev-license-api-key-change-me-xxxxx

# 认证模式: mock / email
# mock: 验证码固定 123456（仅开发测试）
# email: 通过 SMTP 发送真实验证码（生产必须使用）
AUTH_MODE=mock

# SMTP 邮件配置（AUTH_MODE=email 时必需）
# 主流服务商示例:
#   阿里云邮件推送: SMTP_HOST=smtpdm.aliyun.com  SMTP_PORT=465(SSL) 或 80/25
#   腾讯云 SES:     SMTP_HOST=smtp.qcloudmail.com SMTP_PORT=465(SSL)
#   Gmail:          SMTP_HOST=smtp.gmail.com      SMTP_PORT=587(TLS)
#   163:            SMTP_HOST=smtp.163.com         SMTP_PORT=465(SSL)
# 注意: 465 端口用 SMTP_SSL（QQ 邮箱等，代码自动识别），587 端口用 STARTTLS
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
